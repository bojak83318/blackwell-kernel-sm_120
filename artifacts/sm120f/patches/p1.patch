diff --git a/vllm/platforms/cuda.py b/vllm/platforms/cuda.py
index 2025c41ab..470df4e65 100644
--- a/vllm/platforms/cuda.py
+++ b/vllm/platforms/cuda.py
@@ -501,6 +501,33 @@ class CudaPlatformBase(Platform):
     def use_custom_op_collectives(cls) -> bool:
         return True
 
+    @classmethod
+    def is_sm120f(cls) -> bool:
+        capability = cls.get_device_capability()
+        if capability is None or capability.major != 12:
+            return False
+        # compute_120f requires CUDA >= 13.0
+        is_f = torch.version.cuda is not None and float(
+            torch.version.cuda[:4]) >= 13.0
+        if is_f:
+            logger.info_once("Detected Blackwell SM120 with CUDA >= 13.0. "
+                             "Using compute_120f (full TMA) path.")
+        return is_f
+
+    @classmethod
+    def is_sm120a(cls) -> bool:
+        capability = cls.get_device_capability()
+        if capability is None or capability.major != 12:
+            return False
+        # compute_120a is the fallback for Blackwell on CUDA < 13.0
+        is_a = not cls.is_sm120f()
+        if is_a:
+            logger.info_once(
+                "Detected Blackwell SM120 with CUDA < 13.0 (%s). "
+                "Falling back to compute_120a (basic FP4) path.",
+                torch.version.cuda)
+        return is_a
+
 
